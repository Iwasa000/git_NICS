// midori 180404 add -->
//**********************************************************************
// CSVの1行分のデータをテーブルに登録（インポート用）
//		・データをテーブルに格納する形式に変換
//		・テーブルに登録
// 
//	引数
//			pstrCsvDataAry			[IN] CSVの1行分のデータ
// 
//	戻値
//			レコード（行）の種類（DBUchiImpDEF.h参照）
//**********************************************************************
//virtual
int CimpUc092Kaikakekin2::ImpCsvOneLineData(CStringArray* pstrCsvDataAry)
{
	//--------------------------------------------------
	// 前処理（全帳票共通のコード）
	//--------------------------------------------------
	int				ii=0;
	int				sw=0;
// 修正No.157653 add -->
	int				len=0;
// 修正No.157653 add <--
	long			nSpDate=0;
	CString			strTemp = _T("");		// 文字列テンポラリ
// midori UC_0054 add -->
	CString			strCsvId = _T("");
// midori UC_0054 add <--

	// 01 支払確定年月日
	if (pstrCsvDataAry->GetAt(1) != _T("")) {
		// エラーの場合、クリアーする
		if (ConvDateStrToDbVal(IMP_DATE_CONV_TYPE_A, pstrCsvDataAry->GetAt(1), &nSpDate) != TRUE) {
			nSpDate = 0;
			strTemp.Empty();
			pstrCsvDataAry->SetAt(1,strTemp);
		}
	}

	// 02 期末現在高
	// エラーの場合、クリアーする
// 修正No.157653 del -->
	//if (CheckImportNum(pstrCsvDataAry->GetAt(2), 12, TRUE) != TRUE) {		// [2009/07/09 Minus Value Support]
// 修正No.157653 del <--
// 修正No.157653 add -->
	if(bG_Kanso == TRUE)	len = 13;
	else					len = 12;
	if (CheckImportNum(pstrCsvDataAry->GetAt(2), len, TRUE) != TRUE) {		// [2009/07/09 Minus Value Support]
// 修正No.157653 add <--
		strTemp.Empty();
		pstrCsvDataAry->SetAt(2,strTemp);
	}

// midori UC_0054 add -->
	strCsvId = pstrCsvDataAry->GetAt(0);
// midori 155543 del -->
	//if ((strCsvId.Compare(CSV_ID_DATA) == 0) ||
	//	(strCsvId.Compare(CSV_ID_UCHIWAKE) == 0) ||
	//	(strCsvId.Compare(CSV_ID_HAITOKIN) == 0) ||
	//	(strCsvId.Compare(CSV_ID_YAKUINSYOYO) == 0)) {
// midori 155543 del <--
// midori 155543 add -->
	if (((strCsvId.Compare(CSV_ID_DATA) == 0) ||
		(strCsvId.Compare(CSV_ID_UCHIWAKE) == 0) ||
		(strCsvId.Compare(CSV_ID_HAITOKIN) == 0) ||
		(strCsvId.Compare(CSV_ID_YAKUINSYOYO) == 0)) && m_ErrMap.GetCount() > 0)	{
// midori 155543 add <--
// midori UC_0054 add <--
		// エラー項目クリア後、全ての項目が空白になった場合、処理を行わない
		// データがあるか？
		for (ii = 0; ii <(int)pstrCsvDataAry->GetSize(); ii++) {
			// 先頭は項目名称が格納されているはずなので無視
			if (ii == 0) {
				continue;
			}
			// 1項目でもデータがあればデータ行とみなす
			if (pstrCsvDataAry->GetAt(ii).GetLength() > 0){
				sw = 1;
				break;
			}
		}
		if(sw == 0)	{
			return IMP_REC_OK;
		}
// midori UC_0054 add -->
	}
// midori UC_0054 add <--

	//++++++++++++++++++++++++++++++++++++++++++++++++++
	// テーブル操作の準備
	//++++++++++++++++++++++++++++++++++++++++++++++++++
	// 一時的にテーブルアクセス領域を拡張
	m_pUcData = (CdbUc092Kaikakekin2*)m_pUcCmn;

	//++++++++++++++++++++++++++++++++++++++++++++++++++
	// 名称テーブルへ登録
	//++++++++++++++++++++++++++++++++++++++++++++++++++
	// 名称テーブル登録無し

	// インポートしようとした回数をカウント
	m_nImportCount++;

	//++++++++++++++++++++++++++++++++++++++++++++++++++
	// データ加工
	// テーブルへデータ登録
	//++++++++++++++++++++++++++++++++++++++++++++++++++
	// 新規レコード作成
	m_pUcData->CreateNewRecord();

	// レコード編集開始
	m_pUcData->Edit();

	// XX 頁番号
	// XX 行番号
//	CheckNumPageRow(&m_NumPage, &m_NumRow);
	m_pUcData->m_NumRow			= GetRow(m_nImportCount - 1);
	m_pUcData->m_NumPage		= GetPage(m_nImportCount - 1);

	// 00 特殊行フラグ
	m_pUcData->m_FgFunc			= m_FgFunc;

	// 後からソートを行うために、ダミーエリアに「未払配当金」「未払役員賞与」の区分を
	// 書き込んでおく（0:未払配当金 1:未払役員賞与）
	if(pstrCsvDataAry->GetAt(0) == CSV_ID_HAITOKIN)	{
		m_pUcData->m_RenFgTemp = 0;
	}
	else	{
		m_pUcData->m_RenFgTemp = 1;
	}

	// [明細]の場合のみ各項目のデータを登録
	// [小計]、[中計]は、計文言と頁番号、行番号、特殊行フラグのみ
	// 空行は、頁番号、行番号、特殊行フラグのみ
	switch (m_FgFunc) {
	case	ID_FGFUNC_DATA:			// データ行
		// 01 支払確定年月日
		m_pUcData->m_SpDate		= nSpDate;

		// 02 期末現在高
		m_pUcData->m_Val		= pstrCsvDataAry->GetAt(2);

		break;
	case	ID_FGFUNC_SYOKEI:		// 小計行
		m_pUcData->m_KeiStr		= m_strSyokeiName;
		break;
	case	ID_FGFUNC_CHUKEI:		// 中計行
		m_pUcData->m_KeiStr		= m_strChukeiName;
		break;
	}

	// レコード登録
	m_pUcData->Update();

	return IMP_REC_OK;
}
// midori 180404 add <--

//**********************************************************************
// CSVの1行分のデータをテーブルから取得（エクスポート用）
//		・データの正当性をチェック
//		・データをCSVに記述する形式に変換
// 
//	引数
//			pstrCsvDataAry			[OUT]CSVの1行分のデータ
// 
//	戻値
//			レコード（行）の種類（DBUchiImpDEF.h参照）
//**********************************************************************
//virtual
int CimpUc092Kaikakekin2::GetCsvOneLineData(CStringArray* pstrCsvDataAry)
{
	//--------------------------------------------------
	// 前処理（全帳票共通のコード）
	//--------------------------------------------------
	CString			strCsvId		= _T("");		// CSVの識別子

	int nRet = GetCsvOneLineDataSub(pstrCsvDataAry, &strCsvId);
	// エラーもしくはEOFもしくは一括金額の場合終了
	if (nRet == IMP_REC_NG || 
		nRet == IMP_REC_EOF || 
		nRet == IMP_REC_IKKATU) {
		return nRet;
	}


	//++++++++++++++++++++++++++++++++++++++++++++++++++
	// テーブル操作の準備
	//++++++++++++++++++++++++++++++++++++++++++++++++++
	// 一時的にテーブルアクセス領域を拡張
	m_pUcData = (CdbUc092Kaikakekin2*)m_pUcCmn;


	//++++++++++++++++++++++++++++++++++++++++++++++++++
	// テーブルからデータ取得
	// データ加工
	//++++++++++++++++++++++++++++++++++++++++++++++++++
	CString			strTemp			= _T("");		// 文字列テンポラリ

	// 00 項目名称
	if (m_pUcData->m_NumRow < 3) {
		pstrCsvDataAry->SetAt(0, CSV_ID_HAITOKIN);
	} else {
		pstrCsvDataAry->SetAt(0, CSV_ID_YAKUINSYOYO);
	}

	// [明細]の場合のみ各項目のデータを取得
	// [小計]、[中計]は識別子のみ
	if (strCsvId.Compare(CSV_ID_DATA) == 0) {
		// 01 支払確定年月日
		strTemp = _T("");			// [2009/09/11 Add]
		if (m_pUcData->m_SpDate > 0) {
			ConvDateDbValToStr(IMP_DATE_CONV_TYPE_A, m_pUcData->m_SpDate, &strTemp);
		}
		pstrCsvDataAry->SetAt( 1, strTemp);
		// 02 期末現在高
		pstrCsvDataAry->SetAt( 2, m_pUcData->m_Val);
	}


	//--------------------------------------------------
	// 後処理（全帳票共通のコード）
	//--------------------------------------------------
	// 次のレコードに移動しておく
	m_pUcData->MoveNext();

	return nRet;
}

