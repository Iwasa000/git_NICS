// コンストラクタ
CimpUc092Kaikakekin2::CimpUc092Kaikakekin2(void)
	: CimpUc000Common()
{
	m_pUcData				= NULL;
	iHaitou					= 0;
	iSyouyo					= 0;
// midori 180404 add -->
	m_FgFunc = 0;
// midori 180404 add <--
}

// デストラクタ
CimpUc092Kaikakekin2::~CimpUc092Kaikakekin2(void)
{
}


//**********************************************************************
// 初期処理
// 
//	引数
//			pDB						[IN] DBポインタ
// 
//	戻値
//			エラーコード（DBUchiImpDEF.h参照）
//**********************************************************************
//virtual
int CimpUc092Kaikakekin2::Init(CDatabase* pDB)
{
	//--------------------------------------------------
	// 全帳票共通のコード
	//--------------------------------------------------
	// 共通で使用するテーブルとの接続を開始
	ConnectCmnTables(pDB);


	//++++++++++++++++++++++++++++++++++++++++++++++++++
	// 各帳票固有のコード
	//++++++++++++++++++++++++++++++++++++++++++++++++++
	// 様式シーケンスを指定（ID_FORMNO_XXX）
	m_nFormSeq = 0;		// [欄外]なので様式シーケンスはない

// midori 160609 add -->
	m_nKaikakeRangai = 1;
// midori 160609 add <--

	// 項目数を指定（CSV_XXX_ITEM_CNT）
	m_nItemCount = CSV_092_ITEM_CNT;

	// 内訳書テーブルとの接続を開始
	m_pUcCmn = (CdbUc000Common*)(new CdbUc092Kaikakekin2(pDB));

	m_RowMax = CSV_092_ROW_MAX;

// midori 150954 add -->
	m_pDB = pDB;
// midori 150954 add <--
	//--------------------------------------------------
	// 全帳票共通のコード
	//--------------------------------------------------
	// 小計、中計文言の取得
	//GetKeiStr(m_nFormSeq, &m_strSyokeiName, &m_strChukeiName);		// [欄外]なので計行はない


	return IMP_ERRCODE_SUCCESS;
}

