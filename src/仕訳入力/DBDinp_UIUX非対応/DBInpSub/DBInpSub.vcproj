			<Tool
				Name="VCPreLinkEventTool"
			/>
			<Tool
				Name="VCLinkerTool"
				AdditionalDependencies="ICSGen80D.lib ICSGenl8D.lib ICSArith8D.lib VolDateDB8D.lib DBrecmd8D.lib DBSUBFNC8D.lib dbzmsub8d.lib DBSyz8D.lib VLCTLDB8D.lib DBana8D.lib DBKmsel8D.lib DBPbZmsub8d.lib DBNpSub8d.lib ICSCmnD.lib NpHwCalq8D.lib ImgMng8D.lib Zmgen8d.lib Imm32.lib KaigenInfo8d.lib jz2cloudopt8d.lib TkjourUtilD.lib"
				OutputFile="$(OutDir)\$(ProjectName)8D.dll"
				LinkIncremental="2"
				ModuleDefinitionFile=".\DBInpSubD.def"
				DelayLoadDLLs="DBPbZmsub8d.dll;DBNpSub8d.dll"
				GenerateDebugInformation="true"
				SubSystem="2"
				TargetMachine="1"
