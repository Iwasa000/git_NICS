	</ToolFiles>
	<Configurations>
		<Configuration
			Name="Debug|Win32"
			OutputDirectory="$(SolutionDir)$(ConfigurationName)"
			IntermediateDirectory="$(ConfigurationName)"
			ConfigurationType="2"
			UseOfMFC="2"
			CharacterSet="2"
			>
			<Tool
				Name="VCPreBuildEventTool"
			/>
			<Tool
				Name="VCCustomBuildTool"
				CommandLine="@echo on&#x0D;&#x0A;copy $(TargetPath) E:\ICSDEV\DLL_DEBUG8&#x0D;&#x0A;copy $(OutDir)\$(TargetName).lib E:\ICSDEV\LIB8&#x0D;&#x0A;&#x0D;&#x0A;"
